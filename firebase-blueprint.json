{
  "entities": {
    "User": {
      "title": "User",
      "description": "System user (Admin, Teacher, or Student)",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "teacher", "student"] },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Admission": {
      "title": "Admission",
      "description": "Student admission application",
      "type": "object",
      "properties": {
        "fullName": { "type": "string" },
        "fatherName": { "type": "string" },
        "cnic": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "address": { "type": "string" },
        "classApplyingFor": { "type": "string" },
        "previousQualification": { "type": "string" },
        "totalMarks": { "type": "string" },
        "obtainedMarks": { "type": "string" },
        "previousSchool": { "type": "string" },
        "marks": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["fullName", "fatherName", "phone", "classApplyingFor", "previousQualification", "totalMarks", "obtainedMarks", "status"]
    },
    "Announcement": {
      "title": "Announcement",
      "description": "School announcement or news",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "author": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "content", "createdAt"]
    },
    "Attendance": {
      "title": "Attendance",
      "description": "Student attendance record",
      "type": "object",
      "properties": {
        "studentId": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "status": { "type": "string", "enum": ["present", "absent", "late"] },
        "classId": { "type": "string" }
      },
      "required": ["studentId", "date", "status"]
    },
    "Result": {
      "title": "Result",
      "description": "Student exam result",
      "type": "object",
      "properties": {
        "studentId": { "type": "string" },
        "subject": { "type": "string" },
        "marks": { "type": "number" },
        "totalMarks": { "type": "number" },
        "grade": { "type": "string" },
        "term": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["studentId", "subject", "marks", "totalMarks", "grade"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/admissions/{admissionId}": {
      "schema": "Admission",
      "description": "Admission applications"
    },
    "/announcements/{announcementId}": {
      "schema": "Announcement",
      "description": "School announcements"
    },
    "/attendance/{attendanceId}": {
      "schema": "Attendance",
      "description": "Attendance records"
    },
    "/results/{resultId}": {
      "schema": "Result",
      "description": "Student results"
    }
  }
}
