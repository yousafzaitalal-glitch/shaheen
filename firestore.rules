rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users
    // Fields: uid, email, displayName, role, photoURL, createdAt
    //
    // Collection: admissions
    // Fields: fullName, fatherName, cnic, phone, email, address, classApplyingFor, previousSchool, marks, status, createdAt
    //
    // Collection: announcements
    // Fields: title, content, author, createdAt
    //
    // Collection: attendance
    // Fields: studentId, date, status, classId
    //
    // Collection: results
    // Fields: studentId, subject, marks, totalMarks, grade, term, createdAt
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "yousafzaitalal@gmail.com" && request.auth.token.email_verified == true));
    }

    function isTeacher() {
      return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'teacher';
    }

    function isStudent() {
      return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'student';
    }

    // Domain Validators
    function isValidUser(data) {
      return data.uid is string && data.email is string && data.role in ['admin', 'teacher', 'student'];
    }

    function isValidAdmission(data) {
      return data.fullName is string && data.phone is string && data.status in ['pending', 'approved', 'rejected'];
    }

    // Rules
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isAdmin() || (isOwner(userId) && request.resource.data.role == resource.data.role);
    }

    match /admissions/{admissionId} {
      allow read: if isAdmin();
      allow create: if true; // Public can apply
      allow update, delete: if isAdmin();
    }

    match /announcements/{announcementId} {
      allow read: if true; // Public can see news
      allow create, update, delete: if isAdmin();
    }

    match /attendance/{attendanceId} {
      allow read: if isAdmin() || isTeacher() || (isStudent() && request.auth.uid == resource.data.studentId);
      allow create, update, delete: if isAdmin() || isTeacher();
    }

    match /results/{resultId} {
      allow read: if isAdmin() || isTeacher() || (isStudent() && request.auth.uid == resource.data.studentId);
      allow create, update, delete: if isAdmin() || isTeacher();
    }
  }
}
